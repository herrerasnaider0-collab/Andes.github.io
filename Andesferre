        <div class="wiz-nav">
          <button class="btn btn-ghost btn-sm" onclick="wizGo(2)">← Atrás</button>
          <button class="btn btn-primary btn-sm" onclick="submitRFQ()">Lanzar a subasta ▶</button>
        </div>
      </div>

      <!-- success -->
