          </div>
          <div class="field" style="margin:0">
            <label>Cantidad</label>
            <input type="number" id="matQty" placeholder="500" min="1">
          </div>
          <div class="field" style="margin:0">
            <label>Unidad</label>
            <select id="matUnit">
              <option>unidad</option><option>bolsa</option><option>m³</option>
              <option>ton</option><option>m</option><option>caja</option><option>galón</option>
            </select>
          </div>
          <button class="btn btn-ghost btn-sm" onclick="addMat()">+ Agregar</button>
        </div>
        <div class="mat-list" id="matList"></div>
        <div class="wiz-nav">
          <button class="btn btn-ghost btn-sm" onclick="wizGo(1)">← Atrás</button>
          <button class="btn btn-primary btn-sm" onclick="wizNext(2)">Siguiente →</button>
