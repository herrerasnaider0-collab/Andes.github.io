function scoreOf(s,all){
  const minP=Math.min(...all.map(x=>x.price));
  const minD=Math.min(...all.map(x=>x.days));
  const ps=(minP/s.price)*100, ds=(minD/s.days)*100, rs=s.rating*10;
  return Math.round((ps*.6+ds*.25+rs*.15)*10)/10;
}
function renderAuc(){
  const all=auc.sup;
  const ranked=[...all].map(s=>({...s,sc:scoreOf(s,all)})).sort((a,b)=>b.sc-a.sc);
  const wrap=document.getElementById('aucRank');
  wrap.innerHTML='';
  ranked.forEach((s,i)=>{
    const orig=aucData().find(o=>o.ab===s.ab);
    const diff=orig.price-s.price;
    const d=el('div','bid'+(i===0?' lead':''));
    d.innerHTML=`
      <div class="bid-rank">${i+1}</div>
      <div style="display:flex;gap:12px;align-items:center">
        <div class="bid-av">${s.ab}</div>
        <div class="bid-info"><b>${s.nm}</b>
          <span class="meta">${s.days} días entrega · score hist. ${s.rating}</span></div>
      </div>
      <div class="bid-price">
        <div class="p">${fmt(s.price)}</div>
        <div class="d ${diff>0?'down':''}">${diff>0?'▼ -'+fmt(diff).replace('S/ ',''):'oferta base'}</div>
      </div>
      <div class="bid-score"><div class="sc">${s.sc}</div><div class="sl">Score</div></div>`;
    wrap.appendChild(d);
  });
}
function logLine(txt,cls){
  const log=document.getElementById('aucLog');
  const t=new Date();
  const ts=String(t.getMinutes()).padStart(2,'0')+':'+String(t.getSeconds()).padStart(2,'0');
  const l=el('div','log-line'+(cls?' '+cls:''),`<span class="t">${ts}</span> ${txt}`);
  log.insertBefore(l,log.firstChild);
}
function setTimer(){
  const t=document.getElementById('aucTimer');
  const m=Math.floor(auc.time/60),s=auc.time%60;
  t.textContent=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  t.classList.toggle('crit',auc.time<=10);
}
function auctionStart(){
  if(auc.running||auc.closed)return;
  auc.running=true;
  document.getElementById('aucStart').disabled=true;
  document.getElementById('aucClose').disabled=false;
  logLine('Subasta iniciada. Ventana abierta.');
  toast('Subasta iniciada','Los proveedores comenzaron a pujar.');
  auc.timer=setInterval(()=>{
    auc.time--;
    setTimer();
    // 1-2 suppliers lower their bid
    const n=Math.random()<.5?1:2;
    for(let k=0;k<n;k++){
      const s=auc.sup[Math.floor(Math.random()*auc.sup.length)];
      if(s.price>s.floor){
        const cut=Math.round((80+Math.random()*420)/10)*10;
        s.price=Math.max(s.floor,s.price-cut);
        logLine(`${s.nm} bajó su oferta a <b style="color:#fff">${fmt(s.price)}</b>.`);
      }
    }
    renderAuc();
    if(auc.time<=0)auctionClose();
  },1000);
}
function auctionClose(){
  if(auc.closed)return;
  clearInterval(auc.timer);
  auc.running=false;auc.closed=true;
  auc.time=Math.max(0,auc.time);setTimer();
  document.getElementById('aucClose').disabled=true;
  document.getElementById('aucStart').disabled=true;
  const all=auc.sup;
  const win=[...all].map(s=>({...s,sc:scoreOf(s,all)})).sort((a,b)=>b.sc-a.sc)[0];
  const orig=aucData().find(o=>o.ab===win.ab);
  const saved=Math.round((1-win.price/Math.max(...aucData().map(x=>x.price)))*100);
  logLine(`Adjudicado a <b style="color:#fff">${win.nm}</b> — ${fmt(win.price)}.`,'win');
  const ap=document.getElementById('awardPanel');
  ap.classList.add('show');
  document.getElementById('awardTxt').innerHTML=
    `Proveedor ganador: <b style="color:var(--green)">${win.nm}</b> con oferta de
     <b style="color:#fff">${fmt(win.price)}</b>, score ${win.sc} y entrega en ${win.days} días.
     Ahorro estimado del <b style="color:var(--green)">${saved}%</b> frente al precio más alto.
     El contrato digital fue enviado para firma electrónica.`;
  toast('Subasta adjudicada','Contrato generado para '+win.nm+'.');
}
function auctionReset(){
  clearInterval(auc.timer);
  auc={sup:aucData(),time:40,timer:null,running:false,closed:false};
  document.getElementById('aucStart').disabled=false;
  document.getElementById('aucClose').disabled=true;
  document.getElementById('awardPanel').classList.remove('show');
  document.getElementById('aucLog').innerHTML=
    '<div class="log-line"><span class="t">--:--</span> Subasta lista. 4 proveedores habilitados.</div>';
  setTimer();renderAuc();
}
setTimer();renderAuc();

/* ======================= WIZARD: PORTAL CLIENTE ======================= */
let wizStep=1, materials=[];
function wizGo(n){
  wizStep=n;
  for(let i=1;i<=3;i++){
    document.getElementById('wp'+i).classList.toggle('on',i===n);
    const tab=document.getElementById('wt'+i);
    tab.classList.toggle('active',i===n);
    tab.classList.toggle('done',i<n);
  }
}
function wizNext(from){
  if(from===1){
    if(!document.getElementById('prjName').value.trim()){
      toast('Falta información','Ingresa el nombre del proyecto.');return;
    }
    wizGo(2);
  }else if(from===2){
    if(materials.length===0){
      toast('Sin materiales','Agrega al menos un material para cotizar.');return;
    }
    buildReview();wizGo(3);
  }
}
function addMat(){
  const nm=document.getElementById('matName').value.trim();
  const qty=document.getElementById('matQty').value;
  const unit=document.getElementById('matUnit').value;
  if(!nm||!qty){toast('Dato incompleto','Completa material y cantidad.');return;}
  materials.push({nm,qty,unit});
  document.getElementById('matName').value='';
  document.getElementById('matQty').value='';
  renderMats();
}
function renderMats(){
  const box=document.getElementById('matList');
  if(materials.length===0){
    box.innerHTML='<div class="empty">Aún no hay materiales agregados.</div>';return;
  }
  box.innerHTML='';
  materials.forEach((m,i)=>{
    const it=el('div','mat-item');
    it.innerHTML=`<span><b>${m.nm}</b></span>
      <span class="mq">${m.qty}</span><span style="color:var(--ink-3)">${m.unit}</span>
      <button class="x" onclick="delMat(${i})">×</button>`;
    box.appendChild(it);
  });
}
function delMat(i){materials.splice(i,1);renderMats();}
function buildReview(){
  const b=document.getElementById('reviewBox');
  const matTxt=materials.map(m=>`${m.nm} — ${m.qty} ${m.unit}`).join(' · ');
  b.innerHTML=`
    <div class="rr"><span class="rk">Proyecto</span><span class="rv">${document.getElementById('prjName').value}</span></div>
    <div class="rr"><span class="rk">Categoría</span><span class="rv">${document.getElementById('prjCat').value}</span></div>
    <div class="rr"><span class="rk">Fecha de entrega</span><span class="rv">${document.getElementById('prjDate').value||'Por definir'}</span></div>
    <div class="rr"><span class="rk">Materiales (${materials.length})</span><span class="rv" style="max-width:60%;text-align:right">${matTxt}</span></div>
    <div class="rr"><span class="rk">Ventana de subasta</span><span class="rv">24–72 horas</span></div>`;
}
let rfqCounter=512;
function submitRFQ(){
  rfqCounter++;
  const folio='SA-0'+rfqCounter;
  // add to supplier portal list
  openRFQs.unshift({
    folio:folio,
    title:document.getElementById('prjName').value,
    cat:document.getElementById('prjCat').value,
    items:materials.length,
    matList:materials.map(m=>`${m.nm} (${m.qty} ${m.unit})`),
    window:"72 h",
    offers:0,
    client:"Tu empresa"
  });
  renderRFQGrid();
  document.querySelectorAll('.wiz-pane').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.wiz-tab').forEach(t=>{t.classList.remove('active');t.classList.add('done')});
  document.getElementById('rfqFolio').textContent='#'+folio;
  document.getElementById('rfqSuccess').classList.add('show');
  toast('RFQ #'+folio+' creada','Visible ahora en el Portal de Proveedores.');
}
function resetWizard(){
  materials=[];
  document.getElementById('prjName').value='';
  document.getElementById('prjNotes').value='';
  document.getElementById('prjDate').value='';
  document.getElementById('rfqSuccess').classList.remove('show');
  renderMats();
  wizGo(1);
}
renderMats();

