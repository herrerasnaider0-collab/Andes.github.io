<!-- ============ INICIO ============ -->
<section class="view on" id="v-inicio">
  <div class="hero">
    <div class="hero-grid">
      <div>
        <div class="hero-tag"><span class="dot"></span> Sistema Integral de Cadena de Abastecimiento · v2.0</div>
