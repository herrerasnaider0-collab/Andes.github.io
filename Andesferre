<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ferretería Digital · Sistema Integral con Subasta Inversa</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Saira+Condensed:wght@400;500;600;700;800&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#131210; --bg-1:#1a1813; --bg-2:#221f18; --bg-3:#2c281e;
  --line:#3a3527; --line-soft:#2c2920;
  --ink:#f3efe3; --ink-2:#b3ad99; --ink-3:#787260;
  --amber:#ffb01f; --amber-2:#e08a00; --amber-deep:#b56b00;
  --glow:rgba(255,176,31,.13);
  --steel:#74a9c9; --steel-bg:rgba(116,169,201,.12);
  --green:#5fc27e; --green-bg:rgba(95,194,126,.12);
  --yellow:#f2c14e; --yellow-bg:rgba(242,193,78,.12);
  --red:#ec6a4c; --red-bg:rgba(236,106,76,.13);
  --rad:4px;
  --shadow:0 18px 50px -18px rgba(0,0,0,.7);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  background:var(--bg);
  color:var(--ink);
  font-family:'IBM Plex Sans',sans-serif;
  font-weight:400;
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}
body::before{
  content:"";position:fixed;inset:0;z-index:-2;
  background:
    radial-gradient(900px 500px at 88% -5%, var(--glow), transparent 60%),
    radial-gradient(700px 600px at 5% 105%, rgba(116,169,201,.07), transparent 60%);
}
body::after{
  content:"";position:fixed;inset:0;z-index:-1;opacity:.5;
  background-image:
    linear-gradient(var(--line-soft) 1px, transparent 1px),
    linear-gradient(90deg, var(--line-soft) 1px, transparent 1px);
  background-size:62px 62px;
  -webkit-mask-image:radial-gradient(circle at 50% 40%, #000 0%, transparent 78%);
  mask-image:radial-gradient(circle at 50% 40%, #000 0%, transparent 78%);
}
h1,h2,h3,h4,.disp{font-family:'Saira Condensed',sans-serif;font-weight:700;letter-spacing:.01em;line-height:1.08}
.mono{font-family:'IBM Plex Mono',monospace}
a{color:inherit}
::selection{background:var(--amber);color:#1a1308}

/* ---------- HEADER / NAV ---------- */
header{
  position:sticky;top:0;z-index:100;
  background:rgba(19,18,16,.86);
  backdrop-filter:blur(14px);
  border-bottom:1px solid var(--line);
}
.nav-inner{
  max-width:1320px;margin:0 auto;padding:0 22px;
  display:flex;align-items:center;gap:26px;height:66px;
}
.brand{display:flex;align-items:center;gap:11px;cursor:pointer;flex-shrink:0}
.brand .gear{width:34px;height:34px;flex-shrink:0}
.brand-txt b{font-family:'Saira Condensed',sans-serif;font-weight:800;font-size:18px;letter-spacing:.04em;display:block;line-height:1}
.brand-txt span{font-size:9.5px;letter-spacing:.32em;color:var(--amber);text-transform:uppercase;font-weight:600}
nav{
  display:flex;gap:2px;margin-left:auto;
  overflow-x:auto;scrollbar-width:none;
}
nav::-webkit-scrollbar{display:none}
.nav-btn{
  background:none;border:none;cursor:pointer;
  font-family:'Saira Condensed',sans-serif;font-weight:600;
  font-size:13.5px;letter-spacing:.06em;text-transform:uppercase;
  color:var(--ink-2);padding:9px 13px;border-radius:var(--rad);
  white-space:nowrap;transition:.18s;position:relative;
}
.nav-btn:hover{color:var(--ink);background:var(--bg-2)}
.nav-btn.active{color:var(--amber)}
.nav-btn.active::after{
  content:"";position:absolute;left:13px;right:13px;bottom:-1px;height:2px;
  background:var(--amber);
}

/* ---------- LAYOUT ---------- */
main{max-width:1320px;margin:0 auto;padding:0 22px}
.view{display:none;animation:fade .45s ease}
.view.on{display:block}
@keyframes fade{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
section{padding:54px 0}
.eyebrow{
  display:inline-flex;align-items:center;gap:9px;
  font-family:'IBM Plex Mono',monospace;font-size:11px;
  letter-spacing:.22em;text-transform:uppercase;color:var(--amber);
  margin-bottom:14px;
}
.eyebrow::before{content:"";width:26px;height:1px;background:var(--amber)}
.sec-title{font-size:clamp(28px,4vw,42px);margin-bottom:10px}
.sec-sub{color:var(--ink-2);max-width:660px;font-size:15px;margin-bottom:30px}

/* ---------- HERO ---------- */
.hero{padding:74px 0 60px;position:relative}
.hero-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:48px;align-items:center}
.hero-tag{
  display:inline-flex;align-items:center;gap:10px;
  border:1px solid var(--line);background:var(--bg-1);
  padding:7px 13px;border-radius:100px;font-size:12px;
  color:var(--ink-2);margin-bottom:24px;
}
.hero-tag .dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 9px var(--green)}
.hero h1{font-size:clamp(40px,6.6vw,82px);font-weight:800;letter-spacing:-.005em}
.hero h1 .out{
  -webkit-text-stroke:1.5px var(--amber);color:transparent;
}
.hero h1 .fill{color:var(--amber)}
.hero-lead{color:var(--ink-2);font-size:16.5px;margin:22px 0 30px;max-width:540px}
.hero-cta{display:flex;gap:14px;flex-wrap:wrap}
.btn{
  font-family:'Saira Condensed',sans-serif;font-weight:700;
  font-size:15px;letter-spacing:.05em;text-transform:uppercase;
  padding:13px 24px;border-radius:var(--rad);cursor:pointer;
  border:1px solid transparent;transition:.18s;display:inline-flex;
  align-items:center;gap:9px;
}
.btn-primary{background:var(--amber);color:#1a1308;border-color:var(--amber)}
.btn-primary:hover{background:var(--amber-2);transform:translateY(-2px)}
.btn-ghost{background:transparent;color:var(--ink);border-color:var(--line)}
.btn-ghost:hover{border-color:var(--amber);color:var(--amber)}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none!important}
.btn-sm{padding:9px 16px;font-size:13px}

/* hero panel */
.hero-panel{
  background:var(--bg-1);border:1px solid var(--line);border-radius:8px;
  padding:24px;position:relative;box-shadow:var(--shadow);
}
.hero-panel::before{
  content:"";position:absolute;inset:0;border-radius:8px;pointer-events:none;
  background:linear-gradient(160deg,rgba(255,176,31,.07),transparent 45%);
}
.hp-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px}
.hp-head h4{font-size:18px}
.hp-live{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.18em;
  color:var(--green);display:flex;align-items:center;gap:6px}
.hp-live::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--green);
  animation:pulse 1.6s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.25}}
.hp-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:11px 12px;border-radius:var(--rad);margin-bottom:7px;
  background:var(--bg-2);border:1px solid var(--line-soft);font-size:13px;
}
.hp-row .nm{display:flex;align-items:center;gap:9px}
.hp-row .av{width:26px;height:26px;border-radius:5px;background:var(--bg-3);
  display:grid;place-items:center;font-family:'Saira Condensed';font-weight:700;
  font-size:13px;color:var(--amber)}
.hp-row .pr{font-family:'IBM Plex Mono';font-weight:600;font-size:14px}
.hp-row.win{border-color:var(--green);background:var(--green-bg)}
.hp-row.win .pr{color:var(--green)}
.hp-bar{height:5px;background:var(--bg-3);border-radius:3px;margin-top:14px;overflow:hidden}
.hp-bar i{display:block;height:100%;background:var(--amber);width:62%;border-radius:3px}

/* stat strip */
.stat-strip{
  display:grid;grid-template-columns:repeat(4,1fr);gap:1px;
  background:var(--line);border:1px solid var(--line);border-radius:6px;
  margin-top:54px;overflow:hidden;
}
.stat-cell{background:var(--bg-1);padding:22px 20px}
.stat-cell .v{font-family:'Saira Condensed';font-weight:800;font-size:34px;color:var(--amber);line-height:1}
.stat-cell .l{font-size:12px;color:var(--ink-2);margin-top:6px;letter-spacing:.02em}

/* ---------- CARDS / GRIDS ---------- */
.card{
  background:var(--bg-1);border:1px solid var(--line);border-radius:7px;
  padding:22px;transition:.2s;
}
.card.hov:hover{border-color:var(--amber);transform:translateY(-3px)}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}

/* value prop table */
.vp-card{display:flex;flex-direction:column;gap:14px}
.vp-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;align-items:stretch}
.vp-prob,.vp-sol{padding:16px;border-radius:var(--rad);font-size:14px}
.vp-prob{background:var(--red-bg);border-left:3px solid var(--red)}
.vp-sol{background:var(--green-bg);border-left:3px solid var(--green)}
.vp-prob b,.vp-sol b{font-family:'Saira Condensed';font-size:11px;letter-spacing:.14em;
  text-transform:uppercase;display:block;margin-bottom:4px}
.vp-prob b{color:var(--red)}.vp-sol b{color:var(--green)}

/* module cards */
.mod-card{position:relative;overflow:hidden}
.mod-id{font-family:'Saira Condensed';font-weight:800;font-size:13px;
  color:var(--amber);letter-spacing:.1em}
.mod-card h4{font-size:20px;margin:8px 0 7px}
.mod-card p{font-size:13.5px;color:var(--ink-2)}
.mod-tech{margin-top:14px;display:flex;gap:6px;flex-wrap:wrap}
.chip{font-family:'IBM Plex Mono';font-size:10.5px;padding:4px 9px;border-radius:3px;
  background:var(--bg-3);border:1px solid var(--line);color:var(--ink-2)}
.mod-card .num-bg{position:absolute;right:-8px;bottom:-26px;font-family:'Saira Condensed';
  font-weight:800;font-size:120px;color:var(--bg-2);z-index:0;line-height:1}
.mod-card>*{position:relative;z-index:1}

/* flow steps */
.flow{display:flex;flex-direction:column;gap:2px;margin-top:8px}
.flow-step{display:flex;gap:16px;padding:14px 0;border-bottom:1px solid var(--line-soft)}
.flow-step:last-child{border:none}
.flow-n{flex-shrink:0;width:34px;height:34px;border-radius:6px;background:var(--bg-2);
  border:1px solid var(--line);display:grid;place-items:center;
  font-family:'Saira Condensed';font-weight:800;color:var(--amber);font-size:16px}
.flow-step .ft b{font-family:'Saira Condensed';font-size:15px;letter-spacing:.02em}
.flow-step .ft p{font-size:13px;color:var(--ink-2);margin-top:2px}

/* ---------- TABLES ---------- */
.tbl{width:100%;border-collapse:collapse;font-size:13.5px}
.tbl th{
  font-family:'Saira Condensed';font-weight:700;text-transform:uppercase;
  letter-spacing:.06em;font-size:12px;color:var(--ink-2);text-align:left;
  padding:11px 13px;border-bottom:1px solid var(--line);
}
.tbl td{padding:11px 13px;border-bottom:1px solid var(--line-soft)}
.tbl tr:last-child td{border-bottom:none}
.tbl tbody tr:hover{background:var(--bg-2)}
.tbl-wrap{background:var(--bg-1);border:1px solid var(--line);border-radius:7px;overflow:hidden}
.tbl-wrap.scroll{overflow-x:auto}

/* badges */
.bdg{font-family:'IBM Plex Mono';font-size:10.5px;font-weight:600;padding:3px 9px;
  border-radius:3px;letter-spacing:.04em;display:inline-block;white-space:nowrap}
.bdg.g{background:var(--green-bg);color:var(--green)}
.bdg.y{background:var(--yellow-bg);color:var(--yellow)}
.bdg.r{background:var(--red-bg);color:var(--red)}
.bdg.s{background:var(--steel-bg);color:var(--steel)}
.bdg.a{background:var(--glow);color:var(--amber)}

/* ---------- AUCTION ---------- */
.auc-wrap{display:grid;grid-template-columns:1.55fr 1fr;gap:20px}
.auc-board{background:var(--bg-1);border:1px solid var(--line);border-radius:8px;overflow:hidden}
.auc-head{padding:18px 22px;border-bottom:1px solid var(--line);
  display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap}
.auc-head h4{font-size:20px}
.auc-head .folio{font-family:'IBM Plex Mono';font-size:11px;color:var(--ink-3);margin-top:3px}
.timer-box{text-align:right}
.timer{font-family:'IBM Plex Mono';font-weight:600;font-size:30px;color:var(--amber);line-height:1}
.timer.crit{color:var(--red);animation:pulse 1s infinite}
.timer-box .tl{font-size:10px;letter-spacing:.16em;color:var(--ink-3);text-transform:uppercase}
.auc-items{padding:14px 22px;background:var(--bg-2);font-size:12.5px;color:var(--ink-2);
  display:flex;gap:22px;flex-wrap:wrap}
.auc-items span b{color:var(--ink);font-family:'IBM Plex Mono';font-size:12.5px}
.auc-rank{padding:10px 14px}
.bid{display:grid;grid-template-columns:auto 1fr auto auto;gap:14px;align-items:center;
  padding:14px;border-radius:6px;margin:7px 0;background:var(--bg-2);
  border:1px solid var(--line-soft);transition:.3s;position:relative}
.bid.lead{border-color:var(--green);background:var(--green-bg)}
.bid.lead::before{content:"LÍDER";position:absolute;top:-8px;left:14px;
  font-family:'Saira Condensed';font-weight:700;font-size:9.5px;letter-spacing:.12em;
  background:var(--green);color:#0e1a10;padding:2px 8px;border-radius:3px}
.bid-rank{font-family:'Saira Condensed';font-weight:800;font-size:22px;color:var(--ink-3);width:26px}
.bid.lead .bid-rank{color:var(--green)}
.bid-av{width:40px;height:40px;border-radius:7px;background:var(--bg-3);
  display:grid;place-items:center;font-family:'Saira Condensed';font-weight:700;
  font-size:16px;color:var(--amber);border:1px solid var(--line)}
.bid-info b{font-family:'Saira Condensed';font-size:16px;display:block;letter-spacing:.02em}
.bid-info .meta{font-size:11.5px;color:var(--ink-3);font-family:'IBM Plex Mono'}
.bid-price{text-align:right}
.bid-price .p{font-family:'IBM Plex Mono';font-weight:600;font-size:18px}
.bid.lead .bid-price .p{color:var(--green)}
.bid-price .d{font-size:10.5px;color:var(--ink-3)}
.bid-price .d.down{color:var(--green)}
.bid-score{text-align:center;min-width:60px}
.bid-score .sc{font-family:'Saira Condensed';font-weight:800;font-size:22px;color:var(--amber)}
.bid-score .sl{font-size:9px;letter-spacing:.12em;color:var(--ink-3);text-transform:uppercase}

.auc-side{display:flex;flex-direction:column;gap:16px}
.weight-card .wt{display:flex;justify-content:space-between;font-size:13px;
  padding:8px 0;border-bottom:1px solid var(--line-soft)}
.weight-card .wt:last-child{border:none}
.weight-card .wt .pct{font-family:'IBM Plex Mono';font-weight:600;color:var(--amber)}
.log{background:var(--bg-2);border:1px solid var(--line-soft);border-radius:6px;
  padding:12px;height:175px;overflow-y:auto;font-family:'IBM Plex Mono';font-size:11.5px}
.log-line{padding:3px 0;color:var(--ink-2);border-bottom:1px dashed var(--line-soft)}
.log-line:last-child{border:none}
.log-line .t{color:var(--amber)}
.log-line.win{color:var(--green)}
.award-panel{background:var(--green-bg);border:1px solid var(--green);border-radius:7px;
  padding:18px;display:none}
.award-panel.show{display:block;animation:fade .4s}
.award-panel h4{color:var(--green);font-size:18px;margin-bottom:6px}
.award-panel p{font-size:13px;color:var(--ink-2)}

/* ---------- WIZARD ---------- */
.wiz-steps{display:flex;gap:0;margin-bottom:26px}
.wiz-tab{flex:1;text-align:center;padding:14px 8px;border-bottom:2px solid var(--line);
  position:relative;transition:.2s}
.wiz-tab.active{border-color:var(--amber)}
.wiz-tab.done{border-color:var(--green)}
.wiz-tab .wn{font-family:'Saira Condensed';font-weight:800;font-size:13px;
  width:26px;height:26px;border-radius:50%;display:inline-grid;place-items:center;
  background:var(--bg-2);border:1px solid var(--line);color:var(--ink-3);margin-bottom:5px}
.wiz-tab.active .wn{background:var(--amber);color:#1a1308;border-color:var(--amber)}
.wiz-tab.done .wn{background:var(--green);color:#0e1a10;border-color:var(--green)}
.wiz-tab .wl{font-family:'Saira Condensed';font-weight:600;font-size:13px;
  display:block;color:var(--ink-2);text-transform:uppercase;letter-spacing:.04em}
.wiz-tab.active .wl{color:var(--ink)}
.wiz-pane{display:none}
.wiz-pane.on{display:block;animation:fade .35s}

.field{margin-bottom:16px}
.field label{font-family:'Saira Condensed';font-weight:600;font-size:13px;
  letter-spacing:.04em;text-transform:uppercase;color:var(--ink-2);display:block;margin-bottom:6px}
.field input,.field select,.field textarea{
  width:100%;background:var(--bg-2);border:1px solid var(--line);border-radius:var(--rad);
  padding:11px 13px;color:var(--ink);font-family:'IBM Plex Sans';font-size:14px;
}
.field input:focus,.field select:focus,.field textarea:focus{
  outline:none;border-color:var(--amber)}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}

.mat-add{display:grid;grid-template-columns:2.4fr 1fr 1fr auto;gap:10px;align-items:end}
.mat-list{margin-top:16px}
.mat-item{display:grid;grid-template-columns:1fr auto auto auto;gap:12px;
  align-items:center;padding:11px 14px;background:var(--bg-2);
  border:1px solid var(--line-soft);border-radius:var(--rad);margin-bottom:7px;font-size:13.5px}
.mat-item .mq{font-family:'IBM Plex Mono';color:var(--amber)}
.mat-item .x{cursor:pointer;color:var(--ink-3);font-size:18px;line-height:1;
  background:none;border:none}
.mat-item .x:hover{color:var(--red)}
.empty{text-align:center;padding:26px;color:var(--ink-3);font-size:13px;
  border:1px dashed var(--line);border-radius:var(--rad)}

.wiz-nav{display:flex;justify-content:space-between;margin-top:24px}
.review-box{background:var(--bg-2);border:1px solid var(--line);border-radius:6px;padding:18px}
.review-box .rr{display:flex;justify-content:space-between;padding:7px 0;
  border-bottom:1px solid var(--line-soft);font-size:13.5px}
.review-box .rr:last-child{border:none}
.review-box .rr .rk{color:var(--ink-2)}
.review-box .rr .rv{font-family:'IBM Plex Mono';font-weight:500}

.success-card{text-align:center;padding:40px 24px;background:var(--green-bg);
  border:1px solid var(--green);border-radius:8px;display:none}
.success-card.show{display:block;animation:fade .4s}
.success-card .chk{width:60px;height:60px;border-radius:50%;background:var(--green);
  display:grid;place-items:center;margin:0 auto 16px}
.success-card h3{color:var(--green);font-size:24px;margin-bottom:6px}
.success-card .folio-big{font-family:'IBM Plex Mono';font-size:22px;color:var(--amber);
  margin:12px 0;letter-spacing:.05em}

/* ---------- DASHBOARD ---------- */
.kpi{display:flex;flex-direction:column;gap:6px}
.kpi .kv{font-family:'Saira Condensed';font-weight:800;font-size:38px;line-height:1;color:var(--ink)}
.kpi .kv .u{font-size:18px;color:var(--ink-2)}
.kpi .kl{font-size:12.5px;color:var(--ink-2)}
.kpi .kt{font-family:'IBM Plex Mono';font-size:11px;display:flex;align-items:center;gap:5px}
.kpi .kt.up{color:var(--green)}.kpi .kt.dn{color:var(--red)}
.kpi-ic{width:36px;height:36px;border-radius:7px;background:var(--glow);
  display:grid;place-items:center;margin-bottom:4px}

/* seasonality chart */
.chart-card{background:var(--bg-1);border:1px solid var(--line);border-radius:7px;padding:24px}
.season-chart{display:flex;align-items:flex-end;gap:8px;height:230px;
  margin-top:14px;padding-top:10px;position:relative}
.season-chart .baseline{position:absolute;left:0;right:0;border-top:1px dashed var(--steel);
  z-index:1}
.season-chart .baseline span{position:absolute;right:0;top:-9px;font-family:'IBM Plex Mono';
  font-size:9.5px;color:var(--steel);background:var(--bg-1);padding:0 4px}
.sc-bar{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;height:100%;
  justify-content:flex-end;position:relative}
.sc-bar .col{width:100%;border-radius:3px 3px 0 0;transition:height .7s cubic-bezier(.2,.8,.2,1);
  position:relative;min-height:4px}
.sc-bar .col.g{background:linear-gradient(var(--green),rgba(95,194,126,.35))}
.sc-bar .col.y{background:linear-gradient(var(--yellow),rgba(242,193,78,.35))}
.sc-bar .col.r{background:linear-gradient(var(--red),rgba(236,106,76,.4))}
.sc-bar .val{position:absolute;top:-18px;font-family:'IBM Plex Mono';font-size:10px;
  color:var(--ink-2);width:100%;text-align:center}
.sc-bar .mo{font-family:'Saira Condensed';font-weight:600;font-size:11px;color:var(--ink-3)}
.legend{display:flex;gap:18px;margin-top:18px;flex-wrap:wrap}
.legend span{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--ink-2)}
.legend i{width:11px;height:11px;border-radius:2px}

.alert-list{display:flex;flex-direction:column;gap:9px}
.alert-it{display:flex;gap:12px;padding:13px;border-radius:6px;align-items:flex-start}
.alert-it.r{background:var(--red-bg);border-left:3px solid var(--red)}
.alert-it.y{background:var(--yellow-bg);border-left:3px solid var(--yellow)}
.alert-it.g{background:var(--green-bg);border-left:3px solid var(--green)}
.alert-it .ai{width:30px;height:30px;border-radius:6px;flex-shrink:0;display:grid;
  place-items:center;font-family:'Saira Condensed';font-weight:800;font-size:13px}
.alert-it.r .ai{background:var(--red);color:#1a0d0a}
.alert-it.y .ai{background:var(--yellow);color:#1a1408}
.alert-it.g .ai{background:var(--green);color:#0d1a10}
.alert-it b{font-family:'Saira Condensed';font-size:14.5px;display:block}
.alert-it p{font-size:12.5px;color:var(--ink-2);margin-top:1px}

/* ---------- SUPPLIERS ---------- */
.sup-card{position:relative}
.sup-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
.sup-id{display:flex;gap:12px;align-items:center}
.sup-av{width:46px;height:46px;border-radius:8px;background:var(--bg-3);
  border:1px solid var(--line);display:grid;place-items:center;
  font-family:'Saira Condensed';font-weight:800;font-size:18px;color:var(--amber)}
.sup-id b{font-family:'Saira Condensed';font-size:17px;display:block;letter-spacing:.02em}
.sup-id .cat{font-size:11.5px;color:var(--ink-3);font-family:'IBM Plex Mono'}
.score-ring{text-align:center}
.score-ring .sv{font-family:'Saira Condensed';font-weight:800;font-size:30px;line-height:1}
.score-ring .sl{font-size:9px;letter-spacing:.14em;color:var(--ink-3);text-transform:uppercase}
.sup-stats{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:6px}
.sup-stat{background:var(--bg-2);border-radius:var(--rad);padding:9px 11px}
.sup-stat .v{font-family:'IBM Plex Mono';font-weight:600;font-size:15px;color:var(--ink)}
.sup-stat .l{font-size:10.5px;color:var(--ink-3)}
.score-bar{height:6px;background:var(--bg-3);border-radius:3px;margin-top:13px;overflow:hidden}
.score-bar i{display:block;height:100%;border-radius:3px}

/* ---------- RISK MATRIX ---------- */
.risk-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
.risk-card{background:var(--bg-1);border:1px solid var(--line);border-radius:7px;
  padding:18px;border-left-width:3px}
.risk-card.critico{border-left-color:var(--red)}
.risk-card.alto{border-left-color:var(--yellow)}
.risk-card.medio{border-left-color:var(--steel)}
.risk-card h4{font-size:15.5px;margin-bottom:10px;display:flex;justify-content:space-between;
  align-items:center;gap:10px}
.risk-meters{display:flex;gap:18px;font-size:12px;color:var(--ink-2)}
.risk-meters .rm b{font-family:'IBM Plex Mono';color:var(--ink);display:block;font-size:14px}

.proto{background:var(--bg-1);border:1px solid var(--line);border-radius:7px;
  margin-bottom:12px;overflow:hidden}
.proto-head{padding:16px 20px;cursor:pointer;display:flex;justify-content:space-between;
  align-items:center;gap:14px;transition:.18s}
.proto-head:hover{background:var(--bg-2)}
.proto-tag{font-family:'Saira Condensed';font-weight:800;font-size:14px;color:#1a1308;
  background:var(--amber);padding:4px 10px;border-radius:4px;flex-shrink:0}
.proto-head h4{font-size:16px;flex:1}
.proto-head .arr{font-size:13px;color:var(--ink-3);transition:.25s}
.proto.open .arr{transform:rotate(90deg);color:var(--amber)}
.proto-body{max-height:0;overflow:hidden;transition:max-height .35s ease}
.proto.open .proto-body{max-height:600px}
.proto-body-in{padding:0 20px 18px;border-top:1px solid var(--line-soft)}
.proto-phase{display:flex;gap:13px;padding:12px 0;border-bottom:1px solid var(--line-soft)}
.proto-phase:last-child{border:none}
.proto-phase .ph-t{font-family:'Saira Condensed';font-weight:700;font-size:12px;
  letter-spacing:.06em;text-transform:uppercase;color:var(--amber);flex-shrink:0;width:130px}
.proto-phase p{font-size:13px;color:var(--ink-2)}

/* ---------- TIMELINE ---------- */
.tl{position:relative;padding-left:34px}
.tl::before{content:"";position:absolute;left:11px;top:6px;bottom:6px;width:2px;
  background:var(--line)}
.tl-item{position:relative;padding-bottom:22px}
.tl-item:last-child{padding-bottom:0}
.tl-dot{position:absolute;left:-34px;top:2px;width:24px;height:24px;border-radius:50%;
  background:var(--bg-2);border:2px solid var(--amber);display:grid;place-items:center;
  font-family:'Saira Condensed';font-weight:800;font-size:11px;color:var(--amber)}
.tl-item .tl-head{display:flex;justify-content:space-between;align-items:baseline;
  gap:12px;flex-wrap:wrap;margin-bottom:4px}
.tl-item h4{font-size:16.5px}
.tl-item .tl-meta{font-family:'IBM Plex Mono';font-size:11.5px;color:var(--amber)}
.tl-item p{font-size:13px;color:var(--ink-2)}

.budget-total{display:flex;justify-content:space-between;align-items:center;
  background:var(--glow);border:1px solid var(--amber);border-radius:7px;
  padding:18px 22px;margin-top:16px}
.budget-total .bl{font-family:'Saira Condensed';font-weight:700;font-size:16px;
  text-transform:uppercase;letter-spacing:.04em}
.budget-total .bv{font-family:'Saira Condensed';font-weight:800;font-size:30px;color:var(--amber)}

/* hazard band */
.hazard{height:10px;background:repeating-linear-gradient(45deg,
  var(--amber) 0 18px,#13110d 18px 36px);opacity:.85;margin:0}

/* ---------- FOOTER ---------- */
footer{border-top:1px solid var(--line);margin-top:40px;padding:40px 0 30px;
  background:var(--bg-1)}
.foot-in{max-width:1320px;margin:0 auto;padding:0 22px;
  display:flex;justify-content:space-between;gap:30px;flex-wrap:wrap}
.foot-in .fb{max-width:340px}
.foot-in .fb p{font-size:12.5px;color:var(--ink-3);margin-top:10px}
.foot-cols{display:flex;gap:50px;flex-wrap:wrap}
.foot-col h5{font-family:'Saira Condensed';font-weight:700;font-size:12px;
  letter-spacing:.1em;text-transform:uppercase;color:var(--ink-2);margin-bottom:10px}
.foot-col a{display:block;font-size:13px;color:var(--ink-3);padding:3px 0;cursor:pointer}
.foot-col a:hover{color:var(--amber)}
.foot-base{max-width:1320px;margin:26px auto 0;padding:18px 22px 0;
  border-top:1px solid var(--line-soft);font-size:11.5px;color:var(--ink-3);
  display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px}

.toast{position:fixed;bottom:24px;right:24px;background:var(--bg-3);
  border:1px solid var(--green);border-left-width:3px;border-radius:6px;
  padding:14px 18px;font-size:13.5px;z-index:200;box-shadow:var(--shadow);
  transform:translateY(120px);transition:.35s;max-width:330px}
.toast.show{transform:none}
.toast b{font-family:'Saira Condensed';color:var(--green)}

/* utility */
.split{display:grid;grid-template-columns:1fr 1fr;gap:22px}
.split-12{display:grid;grid-template-columns:1.6fr 1fr;gap:22px}
.mt28{margin-top:28px}.mt16{margin-top:16px}.mb14{margin-bottom:14px}
.theory-card h4{font-size:16px;margin-bottom:7px}
.theory-card .auth{font-family:'IBM Plex Mono';font-size:11px;color:var(--amber);margin-bottom:8px}
.theory-card p{font-size:13px;color:var(--ink-2)}

/* ---------- RESPONSIVE ---------- */
@media(max-width:980px){
  .hero-grid{grid-template-columns:1fr;gap:34px}
  .auc-wrap{grid-template-columns:1fr}
  .split,.split-12,.vp-row{grid-template-columns:1fr}
  .grid-3,.grid-4{grid-template-columns:repeat(2,1fr)}
  .stat-strip{grid-template-columns:repeat(2,1fr)}
  .risk-grid{grid-template-columns:1fr}
}
@media(max-width:620px){
  .nav-inner{gap:14px}
  .grid-3,.grid-4,.grid-2{grid-template-columns:1fr}
  .field-row,.mat-add{grid-template-columns:1fr}
  .season-chart{gap:3px}
  .sc-bar .mo{font-size:9px}
  .bid{grid-template-columns:auto 1fr;grid-auto-rows:auto;gap:8px}
  .bid-price,.bid-score{text-align:left}
  .wiz-tab .wl{font-size:10px}
  section{padding:40px 0}
}
</style>
</head>
